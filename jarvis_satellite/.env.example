# Identidade deste satélite. id deve ser único entre todos os satélites.
SATELLITE_ID=
SATELLITE_NAME=
SATELLITE_LOCATION=

# Token compartilhado só entre este satélite e o cérebro — usado pelo cérebro
# para autenticar comandos enviados a este satélite (Authorization: Bearer).
# Gere um valor aleatório único por satélite, ex: openssl rand -hex 24
SATELLITE_TOKEN=

# Host:porta por onde o CÉREBRO alcança este satélite — IP Tailscale
# 100.x.x.x:porta em produção (localhost:porta só serve para teste local).
SATELLITE_HOST=
SATELLITE_PORT=5001

# URL base do cérebro (jarvis_backend), acessível via Tailscale.
BRAIN_URL=

# Deve ser IDÊNTICO ao SATELLITE_REGISTRATION_SECRET do .env do cérebro.
SATELLITE_REGISTRATION_SECRET=

# Intervalo do heartbeat em ms (padrão: 60000 = 60s).
HEARTBEAT_INTERVAL_MS=60000
