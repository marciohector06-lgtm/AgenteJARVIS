{
  "name": "jarvis-satellite",
  "version": "0.1.0",
  "description": "Agente satélite leve do J.A.R.V.I.S. - recebe ordens do cérebro e executa localmente",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
